{
  "name": "sharabiastore-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Root workspace config for Sharabia Store - Premium Kitchenware E-Commerce",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install",
    "seed": "npm run seed --workspace=backend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
